{
  "name": "art-therapie",
  "version": "0.1.0",
  "private": true,
  "description": "MVP Art Thérapie — monorepo Expo + Next.js",
  "workspaces": [
    "apps/mobile",
    "apps/api"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "mobile:android": "npm run android --workspace=apps/mobile",
    "mobile:ios": "npm run ios --workspace=apps/mobile",
    "mobile:web": "npm run web --workspace=apps/mobile",
    "api": "npm run dev --workspace=apps/api",
    "api:build": "npm run build --workspace=apps/api",
    "dev": "concurrently \"npm run api\" \"npm run mobile\"",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
