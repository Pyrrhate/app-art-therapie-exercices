# Hugging Face — clé serveur uniquement (ne jamais exposer côté client)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Provider IA actif : huggingface | mistral (mistral = placeholder futur)
AI_PROVIDER=huggingface

# Modèles Hugging Face (Inference Providers / router)
# Texte : chat completions OpenAI-compatible
HF_TEXT_MODEL=meta-llama/Llama-3.1-8B-Instruct
# Vision : Qwen2.5-VL via router HF (chat completions multimodal)
HF_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct:fastest

# Rate limiting (requêtes par fenêtre par IP)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# CORS — origines autorisées (séparées par virgule)
# Inclure Expo web (8081/8082) + votre domaine de prod
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006,https://pastek-art.eu
