# Hugging Face — clé serveur uniquement (ne jamais exposer côté client)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Provider IA actif : huggingface | mistral (mistral = placeholder futur)
AI_PROVIDER=huggingface

# --- Modèles recommandés (Vercel → Environment Variables) ---
#
# HF_TEXT_MODEL — génération d'exercices (chat JSON)
#   Recommandé : meta-llama/Llama-3.1-8B-Instruct
#
# HF_VISION_MODEL — analyse photo (chat multimodal via Inference Providers)
#   Recommandé : zai-org/GLM-4.5V:novita
#   Alternative : CohereLabs/aya-vision-32b:cohere
#   Éviter : Qwen/Qwen2.5-VL-7B-Instruct:fastest, llava-hf/* (non routables sur router.huggingface.co)
#
# Sans HF_TOKEN → mode secours (exercices et réflexion génériques).

HF_TEXT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_VISION_MODEL=zai-org/GLM-4.5V:novita

# Rate limiting (requêtes par fenêtre par IP)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# CORS — origines autorisées (séparées par virgule)
# Inclure Expo web (8081/8082) + domaine prod mobile + API
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006,https://pastek-art.eu,https://www.pastek-art.eu
