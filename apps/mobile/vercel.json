{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    { "source": "/fil", "destination": "/app/fil", "permanent": true },
    { "source": "/fil/:id", "destination": "/app/fil/:id", "permanent": true },
    { "source": "/ritual", "destination": "/app/ritual", "permanent": true },
    { "source": "/exercise", "destination": "/app/exercise", "permanent": true },
    { "source": "/reflection", "destination": "/app/reflection", "permanent": true },
    { "source": "/settings", "destination": "/app/settings", "permanent": true },
    { "source": "/privacy", "destination": "/app/privacy", "permanent": true },
    { "source": "/maj", "destination": "/app/maj", "permanent": true }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/" }]
}
